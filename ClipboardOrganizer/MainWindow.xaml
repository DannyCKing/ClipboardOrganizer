<Window x:Class="ClipboardOrganizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:local="clr-namespace:ClipboardOrganizer"
        mc:Ignorable="d" 
        Left="1000" Top="100"
        Title="My Clipboard" Height="800" Width="500" Loaded="Window_Loaded">
    <Window.Resources>
        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation BeginTime="0:0:0"
            Storyboard.TargetName="ToastArea"
            Storyboard.TargetProperty="Opacity"
            From="0.0"
            To="1.0"
            Duration="0:0:0.05"/>
            <DoubleAnimation BeginTime="0:0:0.05"
            Storyboard.TargetName="ToastArea"
            Storyboard.TargetProperty="Opacity"
            From="1.0"
            To="1.0"
            Duration="0:0:0.25"/>
            <DoubleAnimation BeginTime="0:0:0.30"
            Storyboard.TargetName="ToastArea"
            Storyboard.TargetProperty="Opacity"
            From="1.0"
            To="0.0"
            Duration="0:0:1"/>
        </Storyboard>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Green"/>
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="#CC1A1A1A" CornerRadius="4" Padding="9,5">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="White" FontSize="11" FontFamily="Segoe UI"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate DataType="{x:Type local:ClipboardItemViewModel}">
            <Border BorderThickness="0 2 0 2" BorderBrush="Black" >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Background="White">
                        <Label Content="{Binding Number}" VerticalAlignment="Center" Foreground="Black"></Label>
                    </Grid>
                    <Grid Grid.Column="1" Background="white">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Row="0" Grid.ColumnSpan="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="{Binding Name}" />
                            <Border Grid.Column="1" CornerRadius="3" Padding="5,2" Margin="0,5,5,5" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#607D8B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ItemType}" Value="FolderPath">
                                                <Setter Property="Background" Value="#00838F"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ItemType}" Value="URL">
                                                <Setter Property="Background" Value="#1565C0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ItemType}" Value="Password">
                                                <Setter Property="Background" Value="#6A1B9A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ItemTypeDisplay}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                        <Button Grid.Column="0" Grid.Row="1" Command="{Binding OpenCommand}" Height="30" Padding="10" Background="DarkCyan" BorderThickness="0" ToolTip="{Binding OpenTooltip}" ToolTipService.InitialShowDelay="400" ToolTipService.BetweenShowDelay="400">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#005858" TargetName="Border" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ItemType}" Value="FolderPath">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ItemType}" Value="URL">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Grid Width="14" Height="14" VerticalAlignment="Center">
                                        <fa:ImageAwesome Icon="FolderOpen" Foreground="White">
                                            <fa:ImageAwesome.Style>
                                                <Style TargetType="fa:ImageAwesome">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ItemType}" Value="FolderPath">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </fa:ImageAwesome.Style>
                                        </fa:ImageAwesome>
                                        <fa:ImageAwesome Icon="Globe" Foreground="White">
                                            <fa:ImageAwesome.Style>
                                                <Style TargetType="fa:ImageAwesome">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ItemType}" Value="URL">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </fa:ImageAwesome.Style>
                                        </fa:ImageAwesome>
                                    </Grid>
                                    <TextBlock Text="Open" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Grid.Column="0" Grid.Row="1" Command="{Binding RevealCommand}" Height="30" Padding="5" Background="DarkCyan" BorderThickness="0" ToolTip="Show or hide value" ToolTipService.InitialShowDelay="400" ToolTipService.BetweenShowDelay="400">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#4A148C" TargetName="Border"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ItemType}" Value="Password">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ItemType}" Value="String">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Grid Width="14" Height="14" VerticalAlignment="Center">
                                        <fa:ImageAwesome Icon="Eye" Foreground="White">
                                            <fa:ImageAwesome.Style>
                                                <Style TargetType="fa:ImageAwesome">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </fa:ImageAwesome.Style>
                                        </fa:ImageAwesome>
                                        <fa:ImageAwesome Icon="EyeSlash" Foreground="White">
                                            <fa:ImageAwesome.Style>
                                                <Style TargetType="fa:ImageAwesome">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </fa:ImageAwesome.Style>
                                        </fa:ImageAwesome>
                                    </Grid>
                                    <TextBlock Text="{Binding RevealButtonLabel}" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Grid.Row="1" Command="{Binding CopyCommand}" Height="30" Padding="10" Background="#475569" BorderThickness="0" ToolTip="Copy to clipboard" ToolTipService.InitialShowDelay="400" ToolTipService.BetweenShowDelay="400">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Grid.Column" Value="1"/>
                                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="DarkGreen" TargetName="Border" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <fa:ImageAwesome Icon="Copy" Foreground="White" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Copy" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Button.Content>

                        </Button>
                        <Button Grid.Column="2" Grid.Row="1" Command="{Binding EditCommand}" CommandParameter="{Binding}" Height="30" Background="#D97706" BorderThickness="0" Padding="5" ToolTip="Edit item" ToolTipService.InitialShowDelay="400" ToolTipService.BetweenShowDelay="400">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#cc8400" TargetName="Border" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <fa:ImageAwesome Icon="Edit" Foreground="White" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Edit" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Grid.Column="3" Grid.Row="1" Command="{Binding DeleteCommand}" Background="#B91C1C" BorderThickness="0" Height="30" Padding="5" ToolTip="Delete item" ToolTipService.InitialShowDelay="400" ToolTipService.BetweenShowDelay="400">
                            <Button.Content>
                                <fa:ImageAwesome Icon="Trash" Foreground="White" />
                            </Button.Content>
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="DarkRed" TargetName="Border" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Border Grid.Row="2" Grid.ColumnSpan="4" Background="#F3E5F5" Padding="8,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ClipboardValue}" FontFamily="Consolas" FontSize="11" Foreground="#4A148C" TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Grid>

            </Border>

        </DataTemplate>
    </Window.Resources>
    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Command="{Binding AddItemCommand}" Height="36" Background="#2E7D32" BorderThickness="0" Foreground="White" FontSize="14" FontWeight="SemiBold" ToolTip="Add a new clipboard item" ToolTipService.InitialShowDelay="400" ToolTipService.BetweenShowDelay="400">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="Border" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1B5E20" TargetName="Border"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
            + Add Item
        </Button>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ClipboardItems}" />
        </ScrollViewer>
        <Border Grid.Row="1" Name="ToastArea" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Visibility="Collapsed" >
            <Label x:Name="ToastAreaLabel" Visibility="Visible" Content="Copied!"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="2" BorderBrush="Black"
               Background="Green" Height="50" Foreground="White" Margin="10" />
        </Border>
    </Grid>
</Window>
